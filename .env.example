# KUMBHFORCE AI - ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# Copy this file to .env.local for Next.js frontend, or .env for FastAPI backend production deployment.

# ====================================================
# BACKEND API CONFIGURATION
# ====================================================
# The URL pointing to the FastAPI API gateway instance
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws/telemetry

# ====================================================
# SECURITY CONFIGURATION (JWT tokens encryption)
# ====================================================
# Secret key generated via: openssl rand -hex 32
JWT_SECRET_KEY=b8b7d7f76378e907d727e1f40d6c97de96102f1a2380a9d18e38d7d93a9d9f58
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ====================================================
# DATABASE CONFIGURATION
# ====================================================
# For development SQLite database is built under backend/app/kumbhforce.db
DATABASE_URL=sqlite:///./kumbhforce.db

# ====================================================
# LLM / AI GATEWAY ACCESS KEYS
# ====================================================
# Provide API keys for generative RAG summaries and briefings extraction
GEMINI_API_KEY=AIzaSyD-your-gemini-key-here
OPENAI_API_KEY=sk-proj-your-openai-key-here
